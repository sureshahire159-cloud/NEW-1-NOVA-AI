{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile with academic progress details",
      "type": "object",
      "properties": {
        "fullName": {
          "type": "string",
          "description": "The student's full name"
        },
        "email": {
          "type": "string",
          "description": "The authentication email address"
        },
        "phoneNumber": {
          "type": "string",
          "description": "The contact info"
        },
        "location": {
          "type": "string",
          "description": "Indian State/City location details"
        },
        "academicLevel": {
          "type": "string",
          "description": "Indian standard/division Level"
        },
        "board": {
          "type": "string",
          "description": "Selected Indian educational board"
        },
        "schoolCollegeName": {
          "type": "string",
          "description": "Affiliated institute"
        },
        "academicYear": {
          "type": "string",
          "description": "Year of study"
        },
        "xp": {
          "type": "integer",
          "description": "Experience points earned"
        },
        "level": {
          "type": "integer",
          "description": "Calculated study level badge indicator"
        },
        "studyHours": {
          "type": "number",
          "description": "Aggregated daily timer study hours"
        },
        "streak": {
          "type": "integer",
          "description": "Consecutive days completed"
        },
        "completedTasks": {
          "type": "integer",
          "description": "Total closed study task count"
        },
        "completedQuizzes": {
          "type": "integer",
          "description": "Total successfully evaluation test completions"
        },
        "badgeIds": {
          "type": "array",
          "description": "Unlocked reward badge item IDs"
        },
        "avatarUrl": {
          "type": "string",
          "description": "User selected or random avatar image URI"
        },
        "bio": {
          "type": "string",
          "description": "Generated or customizable short user biography"
        }
      },
      "required": [
        "fullName",
        "email",
        "xp",
        "level",
        "streak"
      ]
    },
    "TaskItem": {
      "title": "TaskItem",
      "description": "A customized calendar/academic task",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "Foreign key reference to authenticated profile"
        },
        "title": {
          "type": "string",
          "description": "Task label/title details"
        },
        "completed": {
          "type": "boolean",
          "description": "Task closure boolean active state"
        },
        "dueDate": {
          "type": "string",
          "description": "Calculated calendar due date string"
        },
        "priority": {
          "type": "string",
          "description": "Urgency rating"
        },
        "subject": {
          "type": "string",
          "description": "Subject reference name, optional"
        },
        "createdAt": {
          "type": "string",
          "description": "System-generated task timestamp"
        }
      },
      "required": [
        "userId",
        "title",
        "completed",
        "dueDate",
        "priority",
        "createdAt"
      ]
    },
    "StudyPlan": {
      "title": "StudyPlan",
      "description": "AI formulated micro and macro study plan roadmap",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "Foreign key mapped student"
        },
        "academicLevel": {
          "type": "string",
          "description": "Academic division target"
        },
        "board": {
          "type": "string",
          "description": "CBSE/ICSE etc. board target"
        },
        "subjects": {
          "type": "array",
          "description": "Involved subject lists"
        },
        "dailyHours": {
          "type": "number",
          "description": "Selected study commitment standard hours"
        },
        "examDate": {
          "type": "string",
          "description": "Target board examination countdown date"
        },
        "priorityLevel": {
          "type": "string",
          "description": "Urgency rating scale"
        },
        "weakSubjects": {
          "type": "array",
          "description": "Input checklist of weak subjects"
        },
        "generatedAt": {
          "type": "string",
          "description": "Formula creation timestamp"
        },
        "dailyTimetable": {
          "type": "array",
          "description": "Serialized dynamic daily slots representation"
        },
        "weeklySchedule": {
          "type": "array",
          "description": "Serialized days schedule representation"
        },
        "revisionPlan": {
          "type": "array",
          "description": "Subject-wise spaced milestones"
        },
        "mockTestSchedule": {
          "type": "array",
          "description": "Mock test schedule intervals"
        },
        "examRoadmap": {
          "type": "array",
          "description": "Milestone timeline guide"
        }
      },
      "required": [
        "userId",
        "academicLevel",
        "board",
        "subjects",
        "dailyHours",
        "generatedAt"
      ]
    },
    "DoubtSolveLog": {
      "title": "DoubtSolveLog",
      "description": "Doubt solver resolved solution transcript",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "Mapped student creator"
        },
        "query": {
          "type": "string",
          "description": "Student solved input prompt/text query"
        },
        "subject": {
          "type": "string",
          "description": "Mathematics, Commerce etc. division"
        },
        "solution": {
          "type": "string",
          "description": "AI Generated explanation content markdown transcript"
        },
        "solvedAt": {
          "type": "string",
          "description": "Creation timestamp"
        }
      },
      "required": [
        "userId",
        "query",
        "subject",
        "solution",
        "solvedAt"
      ]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "A student doubt solving conversation thread",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "Foreign key reference to authenticated profile"
        },
        "title": {
          "type": "string",
          "description": "Title of the chat"
        },
        "subject": {
          "type": "string",
          "description": "Academic subject category"
        },
        "topic": {
          "type": "string",
          "description": "Detected or selected study topic"
        },
        "teachingMode": {
          "type": "string",
          "description": "Teaching standard: Beginner, Intermediate, or Advanced"
        },
        "pinned": {
          "type": "boolean",
          "description": "Whether the chat thread is pinned"
        },
        "createdAt": {
          "type": "string",
          "description": "Conversational creation timestamp"
        },
        "updatedAt": {
          "type": "string",
          "description": "Last updated timestamp"
        }
      },
      "required": [
        "userId",
        "title",
        "subject",
        "teachingMode",
        "pinned",
        "createdAt",
        "updatedAt"
      ]
    },
    "ConversationMessage": {
      "title": "ConversationMessage",
      "description": "An individual message in a doubt solver chat history thread",
      "type": "object",
      "properties": {
        "sender": {
          "type": "string",
          "description": "Sender: user or ai"
        },
        "text": {
          "type": "string",
          "description": "Markdown message content"
        },
        "createdAt": {
          "type": "string",
          "description": "Formatted ISO timestamp"
        },
        "imageB64": {
          "type": "string",
          "description": "Optional attached equation image snapshot"
        },
        "voiceUrl": {
          "type": "string",
          "description": "Optional voice input"
        },
        "subject": {
          "type": "string",
          "description": "Smart detected academic subject"
        },
        "topic": {
          "type": "string",
          "description": "Smart detected topic"
        },
        "difficulty": {
          "type": "string",
          "description": "Doubt difficulty level"
        },
        "suggestions": {
          "type": "array",
          "description": "Auto-suggested revision materials, practice questions and quizzes"
        }
      },
      "required": [
        "sender",
        "text",
        "createdAt"
      ]
    }
  },
  "firestore": {
    "profiles/{userId}": {
      "schema": "UserProfile",
      "description": "Student academic account profile records"
    },
    "tasks/{taskId}": {
      "schema": "TaskItem",
      "description": "User scheduled educational tasks list"
    },
    "study_plans/{planId}": {
      "schema": "StudyPlan",
      "description": "Individually customized AI timetable structures"
    },
    "doubts/{doubtId}": {
      "schema": "DoubtSolveLog",
      "description": "Doubt solving transcripts archives"
    },
    "conversations/{conversationId}": {
      "schema": "Conversation",
      "description": "Multi-session ChatGPT style doubt conversations"
    },
    "conversations/{conversationId}/messages/{messageId}": {
      "schema": "ConversationMessage",
      "description": "Individual messages in a specific doubt conversation"
    }
  }
}
